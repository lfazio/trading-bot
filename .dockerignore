# CR-017 Phase A — keep the build context lean (< 50 MB target).

# VCS
.git/
.gitignore
.gitattributes
.gitmodules

# Local dev
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime artefacts — only the baseline report is checked in; both are
# rebuilt by the runtime as needed.
var/

# Wiki submodule — the container doesn't need Markdown docs.
Documentations/

# Tooling that doesn't ship in the image.
tests/
tools/
.rtk/

# Build artefacts.
build/
dist/
*.egg

# CR-016 / CR-009 data + fixtures travel via mounted volumes, not the image.
data/yfinance-fixtures/
.cache/

# Phase-8 hardening C7 — belt-and-suspenders against secrets / state
# leaking into image layers. config/ is bind-mounted at runtime (see
# compose.yaml) so it doesn't belong in the image. The SQLite + .env
# patterns catch operator-local artefacts that should never be
# committed but might slip through during local builds.
config/
*.sqlite
*.sqlite-wal
*.sqlite-shm
.env
.env.*
*.secret
*.key
