    "/events/live-state": {
      "get": {
        "description": "Server-Sent Events channel that pushes the live-state envelope to subscribed clients. Each event's ``id`` is the snapshot's ``as_of`` ISO-8601 timestamp so HTMX `hx-sse` resumes the stream after disconnect.",
        "operationId": "stream_live_state_events_live_state_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "SSE live-state stream"
      }
    },
    "/events/paper-state": {
      "get": {
        "description": "Server-Sent Events channel that pushes the paper-trading session's state envelope to subscribed clients. Each event's ``id`` is the snapshot's ``as_of`` ISO-8601 timestamp so HTMX `hx-sse` resumes the stream after disconnect. Cadence is set by the wired reader's ``tick_seconds`` (default 2s for paper-state vs. 5s for the aggregate live-state \u2014 the paper panel needs to feel live).",
        "operationId": "stream_paper_state_events_paper_state_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "SSE paper-trading state stream"
      }
    },
    "/health": {
      "get": {
        "description": "Return ``{\"status\": \"ok\", \"as_of\": <iso8601>, \"version\": ...}``\nso the container's HEALTHCHECK can poll a stable endpoint without\nauthentication.",
        "operationId": "get_health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response"
          }
        },
        "summary": "Get Health"
      }
    },
