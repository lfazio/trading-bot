    "/onboarding": {
      "get": {
        "description": "GET /onboarding \u2014 render the wizard.\n\nThe step rendered is, in order:\n1. ``?step=<step1|step2|step3>`` query override (used by the\n   \"\u2190 Back\" link to walk backwards without losing the saved\n   inputs).\n2. The step persisted in the signed cookie (so refreshes\n   resume).\n3. ``step1`` for a first-boot visit.\n\nWalking backwards persists the new step into the cookie so a\nfurther refresh stays on the chosen step.",
        "operationId": "get_onboarding_onboarding_get",
        "responses": {
          "200": {
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Onboarding"
      }
    },
    "/onboarding/cancel": {
      "post": {
        "description": "POST /onboarding/cancel \u2014 clear the wizard cookie + redirect to /.",
        "operationId": "post_cancel_onboarding_cancel_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Post Cancel"
      }
    },
    "/onboarding/finish": {
      "post": {
        "description": "POST /onboarding/finish \u2014 finalise the wizard.\n\nREQ_F_PAP_001 + REQ_F_PAP_004 + REQ_F_PAP_005 \u2014 construct a\nticking ``PaperTradingRuntime`` and attach it to the shared\n``RuntimeRegistry`` on ``app.state``. The session's\n``account_id`` is fresh (``paper-<utc-iso-timestamp>``) so\nthe registry's \"one live session per account_id\" invariant\nholds.\n\nStrategy wiring is intentionally skipped in v1 \u2014 the\ncomposed runtime ticks the broker + portfolio + equity\nseries so the dashboard panel paints a live curve. Strategy\n+ risk-engine gating land in a follow-up slice.",
        "operationId": "post_finish_onboarding_finish_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Post Finish"
      }
    },
    "/onboarding/step2": {
      "post": {
        "description": "POST /onboarding/step2 \u2014 validate step 1, advance to step 2.",
        "operationId": "post_step2_onboarding_step2_post",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/Body_post_step2_onboarding_step2_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
