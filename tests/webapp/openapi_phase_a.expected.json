{
  "components": {
    "schemas": {
      "BacktestSubmitRequest": {
        "description": "Body shape for ``POST /api/backtests``.\n\nMirrors the CLI's ``trading-bot backtest`` flags so operators\ncan drive a remote run with the same knobs they'd type locally.",
        "properties": {
          "account_id": {
            "default": "default",
            "title": "Account Id",
            "type": "string"
          },
          "config_dir": {
            "default": "config",
            "description": "config directory inside the container/host",
            "title": "Config Dir",
            "type": "string"
          },
          "end": {
            "description": "backtest end (ISO-8601 with timezone)",
            "format": "date-time",
            "title": "End",
            "type": "string"
          },
          "start": {
            "description": "backtest start (ISO-8601 with timezone)",
            "format": "date-time",
            "title": "Start",
            "type": "string"
          },
          "with_slippage": {
            "default": false,
            "title": "With Slippage",
            "type": "boolean"
          }
        },
        "required": [
          "start",
          "end"
        ],
        "title": "BacktestSubmitRequest",
        "type": "object"
      },
      "Body_jobs_submit_jobs_submit_post": {
        "properties": {
          "account_id": {
            "default": "default",
            "title": "Account Id",
            "type": "string"
          },
          "config_dir": {
            "title": "Config Dir",
            "type": "string"
          },
          "end": {
            "title": "End",
            "type": "string"
          },
          "start": {
            "title": "Start",
            "type": "string"
          },
          "universe": {
            "default": "eu-dividend-starter",
            "title": "Universe",
            "type": "string"
          },
          "with_slippage": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "With Slippage"
          }
        },
        "required": [
          "config_dir",
          "start",
          "end"
        ],
        "title": "Body_jobs_submit_jobs_submit_post",
        "type": "object"
      },
      "Body_operator_recovery_submit_operator_recovery_post": {
        "properties": {
          "backtests_stable": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Backtests Stable"
          },
          "drawdown_recovered": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Drawdown Recovered"
          },
          "integrity_restored": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Integrity Restored"
          },
          "operator_token": {
            "title": "Operator Token",
            "type": "string"
          }
        },
        "required": [
          "operator_token"
        ],
        "title": "Body_operator_recovery_submit_operator_recovery_post",
        "type": "object"
      },
      "Body_post_step2_onboarding_step2_post": {
        "properties": {
          "bar_source": {
            "default": "simulated",
            "title": "Bar Source",
            "type": "string"
          },
          "starting_capital": {
            "title": "Starting Capital",
            "type": "string"
          },
          "universe": {
            "title": "Universe",
            "type": "string"
          }
        },
        "required": [
          "starting_capital",
          "universe"
        ],
        "title": "Body_post_step2_onboarding_step2_post",
        "type": "object"
      },
      "Body_post_step3_onboarding_step3_post": {
        "properties": {
          "strategy": {
            "title": "Strategy",
            "type": "string"
          }
        },
        "required": [
          "strategy"
        ],
        "title": "Body_post_step3_onboarding_step3_post",
        "type": "object"
      },
      "Body_strategies_promote_strategies__strategy_id__promote_post": {
        "properties": {
          "account_id": {
            "default": "default",
            "title": "Account Id",
            "type": "string"
          },
          "operator_id": {
            "title": "Operator Id",
            "type": "string"
          },
          "operator_token": {
            "title": "Operator Token",
            "type": "string"
          },
          "rationale": {
            "title": "Rationale",
            "type": "string"
          }
        },
        "required": [
          "operator_token",
          "operator_id",
          "rationale"
        ],
        "title": "Body_strategies_promote_strategies__strategy_id__promote_post",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "PromoteRequest": {
        "description": "Body schema for ``POST /api/registry/{strategy_id}/promote``.\n\nPydantic validation kicks in at the FastAPI boundary; malformed\nbodies surface as a 422 with the auto-generated detail. The\nAuthorization header carries the Bearer token; the\n``X-Operator-Token`` header carries the action-specific operator\ntoken (kept distinct so the audit row can pair both).",
        "properties": {
          "account_id": {
            "description": "Target account id",
            "minLength": 1,
            "title": "Account Id",
            "type": "string"
          },
          "operator_id": {
            "description": "Acting operator id",
            "minLength": 1,
            "title": "Operator Id",
            "type": "string"
          },
          "rationale": {
            "description": "Promotion rationale",
            "minLength": 1,
            "title": "Rationale",
            "type": "string"
          }
        },
        "required": [
          "account_id",
          "operator_id",
          "rationale"
        ],
        "title": "PromoteRequest",
        "type": "object"
      },
      "SessionRequest": {
        "description": "Body for ``POST /api/session`` \u2014 the operator pastes a token\nissued via the operator-tooling pipeline. ``account_id`` is\n``\"household\"`` for read-scope sessions or the targeted account\nid for mutation-scope sessions.",
        "properties": {
          "account_id": {
            "default": "household",
            "description": "claim the token SHALL carry (defaults to the household sentinel)",
            "title": "Account Id",
            "type": "string"
          },
          "token": {
            "description": "operator HMAC token",
            "minLength": 1,
            "title": "Token",
            "type": "string"
          }
        },
        "required": [
          "token"
        ],
        "title": "SessionRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "FastAPI surface for the trading-bot. Phase A ships the live-state read + registry-promotion mutation + HTMX dashboard. Phase B adds SSE + JobQueue + cookie sessions.",
    "title": "trading-bot webapp",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "description": "Render the Phase-B dashboard.\n\nBrowser path is graceful: a missing or invalid session cookie\nredirects to ``/login`` rather than returning a raw 401 JSON.\nTooling (curl + httpx) still gets the JSON-shaped 401 from the\nother endpoints; only the HTML entry point is browser-friendly.\n\nAuth: any valid token claim (household OR per-account) is\naccepted for the VIEW. Mutation endpoints (registry promotion)\nkeep per-account scoping via ``require_account_token``.",
        "operationId": "dashboard__get",
        "responses": {
          "200": {
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Dashboard"
      }
    },
    "/api/accounts/{account_id}/live-state": {
      "get": {
        "description": "Returns the canonical live-state envelope for the named account. The body shape mirrors the stdlib webui's ``LiveStateResponse`` byte-for-byte.",
        "operationId": "get_live_state_api_accounts__account_id__live_state_get",
        "parameters": [
          {
            "in": "path",
            "name": "account_id",
            "required": true,
            "schema": {
              "title": "Account Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Read live state for an account"
      }
    },
    "/api/accounts/{account_id}/paper-state": {
      "get": {
        "description": "Read endpoint for the paper-trading dashboard panel. Returns a ``PaperStateResponse`` snapshot. When the session is not currently registered (never started, or already stopped), the response is the documented all-zeroed shape with ``is_alive=false`` \u2014 keeps the client-side rendering single-shape.",
        "operationId": "get_paper_state_api_accounts__account_id__paper_state_get",
        "parameters": [
          {
            "in": "path",
            "name": "account_id",
            "required": true,
            "schema": {
              "title": "Account Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Paper-trading session state"
      }
    },
    "/api/backtests": {
      "get": {
        "operationId": "list_backtests_api_backtests_get",
        "responses": {
          "200": {
            "description": "Successful Response"
          }
        },
        "summary": "List submitted backtests"
      },
      "post": {
        "description": "Returns 202 + job_id. The worker runs in a separate process (REQ_NF_WEB_001 child-process isolation). Poll GET /api/backtests/{job_id} or subscribe to GET /events/backtests/{job_id} for progress.",
        "operationId": "submit_backtest_api_backtests_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BacktestSubmitRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Submit an async backtest"
      }
    },
    "/api/backtests/{job_id}": {
      "get": {
        "operationId": "get_backtest_api_backtests__job_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
            "schema": {
              "title": "Job Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Read a single backtest's status + summary"
      }
    },
    "/api/inbox": {
      "get": {
        "description": "Returns the bounded ring buffer of recent operator-facing notifications, newest LAST. The body is canonical-JSON; equal buffer states produce byte-identical bodies.",
        "operationId": "get_inbox_api_inbox_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Notifications inbox snapshot"
      }
    },
    "/api/registry/{strategy_id}/promote": {
      "post": {
        "description": "REQ_F_FAS_001 / REQ_F_FAS_005 \u2014 mutation endpoint gated by the\naccount-scoped operator token.",
        "operationId": "post_promote_api_registry__strategy_id__promote_post",
        "parameters": [
          {
            "in": "path",
            "name": "strategy_id",
            "required": true,
            "schema": {
              "title": "Strategy Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromoteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Promotion accepted"
          },
          "401": {
            "description": "Token invalid"
          },
          "404": {
            "description": "Strategy not found"
          },
          "409": {
            "description": "Already promoted or other categorised Err"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Promote a registered strategy"
      }
    },
    "/api/session": {
      "delete": {
        "operationId": "close_session_api_session_delete",
        "responses": {
          "200": {
            "description": "Successful Response"
          }
        },
        "summary": "Close the cookie session"
      },
      "post": {
        "description": "Verifies the supplied operator token and sets the trading-session cookie (HttpOnly + Secure + SameSite=Strict). Subsequent GETs may omit the Authorization header.",
        "operationId": "open_session_api_session_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Open a cookie-backed session"
      }
    },
    "/events/backtests/{job_id}": {
      "get": {
        "operationId": "stream_backtest_events_backtests__job_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
