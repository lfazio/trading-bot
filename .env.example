# trading-bot — environment variables
# -----------------------------------
# Copy to `.env` (gitignored) and adjust for your environment.
#
# Phase 5 ships a single concrete adapter — `LocalBrokerAdapter` —
# which runs entirely in-process and needs no credentials. Live-broker
# adapters are deferred until a broker is selected through the
# lifecycle; their credential blocks will be added then.

# Logging
TRADING_BOT_LOG_LEVEL=INFO

# Run mode (live | backtest | paper)
TRADING_BOT_MODE=backtest
